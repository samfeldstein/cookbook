---
import Tags from "../Tags.astro";

const { title, tags } = Astro.props;
---

<header>
  <h1 data-pagefind-body>{title}</h1>
  <Tags tags={tags} />
</header>

<style>
  header {
    border-bottom: 1px dashed currentColor;
    margin-bottom: 4rem;
  }

  h1 {
    font-size: 1.25em;
    margin-bottom: 0;
  }
</style>

<style is:global>
  .tags {
    list-style-type: none;
    padding: 0;

    display: flex;
    justify-content: center;
    gap: 0.5em 1em;

    font-size: 0.75em;
  }
</style>
