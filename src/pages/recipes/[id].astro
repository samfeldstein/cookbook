---
import { render } from "astro:content";

// Styles
import "../../styles/global.scss";
import "../../styles/_recipe.scss";

// Components
import Nav from "../../components/Nav.astro";
import Tags from "../../components/Tags.astro";
import WakeLock from "../../components/WakeLock.astro";
import Header from "../../components/recipes/Header.astro";

// Collections
import { getCollection } from "astro:content";

// Functions
// Generate a new path for every collection entry
export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => ({
    params: { id: recipe.id },
    props: { recipe },
  }));
}
// 2. For your template, you can get the entry directly from the prop
const { recipe } = Astro.props;
const { Content } = await render(recipe);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{recipe.data.title} | Cookbook</title>
    <!-- Icons
      - https://evilmartians.com/chronicles/how-to-favicon-in-2021-six-files-that-fit-most-needs
      - Favicon generator: https://realfavicongenerator.net/
      - SVG generator: https://formito.com/tools/favicon
      - Image compressor: https://squoosh.app/
      - SVG optimizer: https://jakearchibald.github.io/svgomg/
      - Favicon checker: https://realfavicongenerator.net/favicon_checker  
    -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>

  <body data-pagefind-body>
    <header>
      <Nav />
      <WakeLock />
    </header>

    <main>
      <Header title={recipe.data.title} tags={recipe.data.tags} />
      {
        Content && (
          <div id="md-content">
            <Content />
          </div>
        )
      }

      <div class="recipe">
        {
          recipe.data.ingredients && (
            <section class="ingredients">
              <h2>Ingredients</h2>
              {Array.isArray(recipe.data.ingredients) &&
              typeof recipe.data.ingredients[0] === "object" ? (
                // sectioned ingredients
                recipe.data.ingredients.map((sec) => (
                  <div class="ingredient-section">
                    <h3>{sec.section}</h3>
                    <ul>
                      {sec.ingredients.map((i) => (
                        <li>{i}</li>
                      ))}
                    </ul>
                  </div>
                ))
              ) : (
                // flat list
                <ul>
                  {recipe.data.ingredients.map((i) => (
                    <li>{i}</li>
                  ))}
                </ul>
              )}
            </section>
          )
        }
        <hr />
        {
          recipe.data.directions && (
            <section class="directions">
              <h2>Directions</h2>
              {Array.isArray(recipe.data.directions) &&
              typeof recipe.data.directions[0] === "object" ? (
                // subsectioned
                recipe.data.directions.map((sec) => (
                  <div class="direction-section">
                    <h3>{sec.section}</h3>
                    <ol>
                      {sec.steps.map((step) => (
                        <li>{step}</li>
                      ))}
                    </ol>
                  </div>
                ))
              ) : (
                <ol>
                  {recipe.data.directions.map((step) => (
                    <li>{step}</li>
                  ))}
                </ol>
              )}
            </section>
          )
        }
      </div>
    </main>
  </body>
</html>

<style lang="scss">
  body {
    background-color: var(--blue);

    max-width: 60rem;

    display: grid;
    gap: 1rem;
  }

  header {
    padding: 1em;
    border-radius: 0.25rem;

    background-color: var(--white);

    -webkit-box-shadow: var(--box-shadow);
    -moz-box-shadow: var(--box-shadow);
    box-shadow: var(--box-shadow);

    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;

    font-size: 0.75em;
  }

  main {
    background-color: var(--white);

    padding: 1em 2em;
    border-radius: 0.25rem;

    -webkit-box-shadow: var(--box-shadow);
    -moz-box-shadow: var(--box-shadow);
    box-shadow: var(--box-shadow);
  }
</style>

<style is:global lang="scss">
  h2 {
    margin-top: 2em;

    font-weight: 400;
    font-size: 1.25em;
    text-decoration: underline;
    text-decoration-thickness: 0.1em;
  }

  #md-content {
    li {
      margin: 0.25em;
      padding: 0.5em;
    }

    strong {
      font-weight: 400;
      text-decoration: underline;
      text-decoration-thickness: 0.1em;
    }
  }
</style>
