---
import Base from "@/layouts/Base.astro";

import Header from "@/components/recipes/Header.astro";

import { components } from "@/components/global";
import { render } from "astro:content";
import { getCollection } from "astro:content";

// Generate a new path for every collection entry
export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => ({
    params: { id: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
---

<Base title={recipe.data.title}>
  <Header title={recipe.data.title} tags={recipe.data.tags} />
    <Content components={components} />
</Base>

<style is:global lang="scss">
  h2 {
    margin-top: 4em;
  }

  strong {
    font-weight: 600;
    text-decoration: underline;
    text-decoration-thickness: 0.1em;
  }

  li {
    margin-bottom: 0.5em;
  }
  
</style>

<script src="@/scripts/wakelock.js"></script>
